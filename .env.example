PORT=4006
INTERNAL_API_SECRET=dev-internal-secret
MEDIA_DIR=./data
# Storage backend precedence: R2 (if all four set) > Vercel Blob > local disk.
# Cloudflare R2 (S3-compatible, private bucket served through this service):
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_BUCKET=luminary-baas-lk
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# Or Vercel Blob instead:
# BLOB_READ_WRITE_TOKEN=
